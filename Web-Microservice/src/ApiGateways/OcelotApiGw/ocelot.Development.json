{
  "GlobalConfiguration": {
    "BaseUrl": "https://localhost:5000"
    
    },
  "Routes": [
    {
      "UpStreamPathTemplate": "/customers/{username}",
      "UpStreamHttpMethod": [ "Get" ],
      "DownstreamPathTemplate": "/api/customers/{username}",
      "Scheme": [ "http" ],
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5003
        }
      ]
    },
    {
      "UpStreamPathTemplate": "/products/{id}",
      "UpStreamHttpMethod": [ "Get" ],
      "DownstreamPathTemplate": "/api/products/{id}",
      "Scheme": [ "http" ],
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5002
        }
      ]
    },
    {
      "UpStreamPathTemplate": "/products/{id}",
      "UpStreamHttpMethod": [  "POST", "DELETE" ],
      "DownstreamPathTemplate": "/api/products/{id}",
      "Scheme": [ "http" ],
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5002
        }
      ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer", //setting in JwtBearerDefaults.AuthenticationScheme
        "AllowedScopes": []
      },
      "RouteClaimsRequirement": {
        "Role": "Admin"
      }
    },
    {
      "UpStreamPathTemplate": "/products",
      "UpStreamHttpMethod": [ "Get", "POST" ],
      "DownstreamPathTemplate": "/api/products",
      "Scheme": [ "http" ],
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5002
        }
      ],
      "RateLimitOptions": {
        "ClientWhitelist": [], //list bypass ratelimit
        "EnableRateLimiting": true,
        "Period": "2s",
        "PeriodTimespan": 1, // thời gian retry
        "Limit": 1 // tổng số request cùng lúc truy cập
      }
    },
    {
      "UpStreamPathTemplate": "/products/get-product-by-no/{itemNo}",
      "UpStreamHttpMethod": [ "Get" ],
      "DownstreamPathTemplate": "/api/products/get-product-by-no/{itemNo}",
      "Scheme": [ "http" ],
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5002
        }
      ]
    },
    {
      "UpStreamPathTemplate": "/baskets/{username}",
